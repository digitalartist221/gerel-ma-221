{
    "name": "digitalartist/madeline-framework",
    "description": "Un framework PHP ultra-moderne, sémantique et performant avec moteur SPA intégré.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Digital Artist Studio",
            "email": "hello@studiodigitalartist.com"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Core\\": "Core/",
            "Packages\\": "Packages/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "serve": "php ligeey serve"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}